@model SIMS.Models.ViewModels.ChangePasswordViewModel
@{
    ViewData["Title"] = "Đổi Mật Khẩu";
    // Tự động bỏ qua Layout chính nếu bạn ép đổi lúc mới đăng nhập (tuỳ chọn)
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Đổi Mật Khẩu</h4>
                </div>
                <div class="card-body">
                    <form asp-action="ChangePassword" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="form-group mb-3">
                            <label asp-for="CurrentPassword"></label>
                            <input asp-for="CurrentPassword" class="form-control" />
                            <span asp-validation-for="CurrentPassword" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="NewPassword"></label>
                            <input asp-for="NewPassword" class="form-control" id="NewPassword" />
                            <span asp-validation-for="NewPassword" class="text-danger"></span>
                            
                            <div class="progress mt-2" style="height: 5px;">
                                <div id="password-strength-bar" class="progress-bar" role="progressbar" style="width: 0%;"></div>
                            </div>
                            <small id="password-strength-text" class="form-text text-muted">Nhập mật khẩu mới...</small>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="ConfirmPassword"></label>
                            <input asp-for="ConfirmPassword" class="form-control" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">Xác nhận đổi mật khẩu</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    
    <script>
        document.getElementById('NewPassword').addEventListener('input', function() {
            var val = this.value;
            var result = 0;
            var progressBar = document.getElementById('password-strength-bar');
            var progressText = document.getElementById('password-strength-text');

            if(val.length > 5) result += 1;
            if(val.length > 8) result += 1;
            if(/[a-z]/.test(val) && /[A-Z]/.test(val)) result += 1; // Có hoa thường
            if(/[0-9]/.test(val)) result += 1; // Có số
            if(/[^a-zA-Z0-9]/.test(val)) result += 1; // Có ký tự đặc biệt

            switch(result) {
                case 0:
                case 1:
                case 2:
                    progressBar.style.width = "33%";
                    progressBar.className = "progress-bar bg-danger";
                    progressText.innerText = "Yếu (Cần thêm số, chữ hoa hoặc ký tự đặc biệt)";
                    progressText.className = "text-danger";
                    break;
                case 3:
                case 4:
                    progressBar.style.width = "66%";
                    progressBar.className = "progress-bar bg-warning";
                    progressText.innerText = "Trung bình";
                    progressText.className = "text-warning";
                    break;
                case 5:
                    progressBar.style.width = "100%";
                    progressBar.className = "progress-bar bg-success";
                    progressText.innerText = "Mạnh (Rất tốt!)";
                    progressText.className = "text-success";
                    break;
            }
            if(val.length === 0) {
                 progressBar.style.width = "0%";
                 progressText.innerText = "Nhập mật khẩu mới...";
            }
        });
    </script>
}