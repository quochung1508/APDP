@model IEnumerable<SIMS.DatabaseContext.Entities.Class>
@{
    ViewData["Title"] = "Quản lý Lớp Học";
}

<div class="card shadow mb-4">
    <div class="card-header py-3 bg-primary text-white d-flex justify-content-between align-items-center">
        <h5 class="m-0 font-weight-bold">Danh sách Lớp Hành Chính</h5>
        <a asp-action="Create" class="btn btn-light btn-sm text-primary fw-bold">Tạo Lớp Mới</a>
    </div>
    <div class="card-body">
        <table class="table table-bordered table-hover">
            <thead class="table-light">
                <tr>
                    <th>Tên Lớp (Class Name)</th>
                    <th>Khóa (Cohort)</th>
                    <th class="text-center">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold align-middle">@item.Name</td>
                        <td class="align-middle">@item.Cohort</td>
                        <td class="text-center">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white"><i class="fas fa-eye"></i> Chi tiết</a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning"><i class="fas fa-edit"></i> Sửa</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i> Xóa</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>