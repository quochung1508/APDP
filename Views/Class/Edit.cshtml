@model SIMS.DatabaseContext.Entities.Class
@{
    ViewData["Title"] = "Sửa Lớp Học";
}

<div class="row">
    <div class="col-md-6 mx-auto">
        <form asp-action="Edit" class="card p-4 shadow-sm">
            <h4 class="mb-3 text-warning"><i class="fas fa-edit"></i> Sửa Thông Tin Lớp</h4>
            <input type="hidden" asp-for="Id" />
            
            <div class="form-group mb-3">
                <label asp-for="Name" class="control-label fw-bold">Tên Lớp</label>
                <input asp-for="Name" class="form-control" required />
            </div>

            <div class="form-group mb-4">
                <label asp-for="Cohort" class="control-label fw-bold">Khóa Học (Cohort)</label>
                <select asp-for="Cohort" class="form-select" required>
                    <option value="Khóa 17">Khóa 17</option>
                    <option value="Khóa 18">Khóa 18</option>
                    <option value="Khóa 19">Khóa 19</option>
                    <option value="Khóa 20">Khóa 20</option>
                </select>
            </div>

            <div class="form-group text-end">
                <a asp-action="Index" class="btn btn-secondary me-2">Hủy</a>
                <button type="submit" class="btn btn-warning text-dark fw-bold">Lưu thay đổi</button>
            </div>
        </form>
    </div>
</div>