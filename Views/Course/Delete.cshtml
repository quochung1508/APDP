@model SIMS.DatabaseContext.Entities.Course
@{
    ViewData["Title"] = "Xóa Khóa Học";
}

<div class="alert alert-danger shadow-sm col-md-6 mx-auto mt-4">
    <h4 class="alert-heading"><i class="fas fa-exclamation-triangle"></i> Cảnh báo!</h4>
    <p>Bạn có chắc chắn muốn xóa khóa học <strong>@Model.Name</strong> (Chuyên ngành: @Model.Major) không?</p>
    <hr>
    <form asp-action="Delete" method="post" class="text-end">
        <input type="hidden" asp-for="Id" />
        <a asp-action="Index" class="btn btn-secondary me-2">Hủy thao tác</a>
        <button type="submit" class="btn btn-danger">Xác nhận Xóa</button>
    </form>
</div>