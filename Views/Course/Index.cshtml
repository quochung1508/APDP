@model IEnumerable<SIMS.DatabaseContext.Entities.Course>
@{
    ViewData["Title"] = "Quản lý Khóa Học";
}

<div class="card shadow mb-4">
    <div class="card-header py-3 bg-success text-white d-flex justify-content-between align-items-center">
        <h5 class="m-0 font-weight-bold">Danh sách Khóa Học / Môn Học</h5>
        <a asp-action="Create" class="btn btn-light btn-sm text-success fw-bold">Tạo Khóa Học Mới</a>
    </div>
    <div class="card-body">
        <table class="table table-bordered table-hover">
            <thead class="table-light">
                <tr>
                    <th>Tên Môn / Khóa Học</th>
                    <th>Chuyên ngành</th>
                    <th>Thời lượng</th>
                    <th class="text-center">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold align-middle">@item.Name</td>
                        <td class="align-middle">@item.Major</td>
                        <td class="align-middle">@item.Duration</td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning"><i class="fas fa-edit"></i> Sửa</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i> Xóa</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>