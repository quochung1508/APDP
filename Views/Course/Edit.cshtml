@model SIMS.DatabaseContext.Entities.Course
@{
    ViewData["Title"] = "Sửa Khóa Học";
}

<div class="row">
    <div class="col-md-7 mx-auto">
        <form asp-action="Edit" class="card p-4 shadow-sm">
            <h4 class="mb-3 text-warning"><i class="fas fa-edit"></i> Cập nhật Khóa Học</h4>
            <input type="hidden" asp-for="Id" />
            
            <div class="form-group mb-3">
                <label asp-for="Name" class="control-label fw-bold">Tên Khóa Học</label>
                <input asp-for="Name" class="form-control" required />
            </div>

            <div class="row mb-3">
                <div class="col-md-6">
                    <label asp-for="Major" class="control-label fw-bold">Chuyên ngành</label>
                    <select asp-for="Major" class="form-select" required>
                        <option value="Công nghệ thông tin">Công nghệ thông tin</option>
                        <option value="Quản trị kinh doanh">Quản trị kinh doanh</option>
                        <option value="Thiết kế đồ họa">Thiết kế đồ họa</option>
                        <option value="Khác">Khác</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label asp-for="Duration" class="control-label fw-bold">Thời gian học</label>
                    <select asp-for="Duration" class="form-select" required>
                        <option value="4 tháng">4 tháng</option>
                        <option value="5 tháng">5 tháng</option>
                        <option value="1 năm">1 năm</option>
                        <option value="Khác">Khác</option>
                    </select>
                </div>
            </div>

            <div class="form-group mb-4">
                <label asp-for="Description" class="control-label fw-bold">Mô tả</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            </div>

            <div class="form-group text-end">
                <a asp-action="Index" class="btn btn-secondary me-2">Hủy</a>
                <button type="submit" class="btn btn-warning text-dark fw-bold">Lưu thay đổi</button>
            </div>
        </form>
    </div>
</div>