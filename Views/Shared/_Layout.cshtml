@{
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <meta name="description" content="" />
    <meta name="author" content="" />
    <title>@ViewData["title"] - SIMS</title>
    <link href="https://cdn.jsdelivr.net/npm/simple-datatables@7.1.2/dist/style.min.css" rel="stylesheet" />
    <link href="~/sims/css/styles.css" rel="stylesheet" />
    <link href="~/css/fpt-btec-style.css" rel="stylesheet" />
    @RenderSection("stylesheets", required: false)
    @RenderSection("Styles", required: false)
</head>
<body class="sb-nav-fixed">
    <partial name="Partials/_Navbar" />
    <div id="layoutSidenav">
        <partial name="Partials/_Sidebar" />
        <div id="layoutSidenav_content">
            <main>
                <div class="container-fluid px-4">
                    <h1 class="mt-4">@ViewData["breadcrumb"]</h1>
                    <ol class="breadcrumb mb-4">
                        <li class="breadcrumb-item active">@ViewData["breadcrumb_item"]</li>
                    </ol>
                    @RenderBody()
                </div>
            </main>
            <partial name="Partials/_Footer" />
        </div>
    </div>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://use.fontawesome.com/releases/v6.3.0/js/all.js" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
    <script src="~/sims/js/scripts.js"></script>
    <partial name="_ValidationScriptsPartial" />
    @RenderSection("javascripts", required: false)
    @RenderSection("Scripts", required: false)
</body>
</html>
