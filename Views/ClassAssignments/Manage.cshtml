@model SIMS.Models.ViewModels.ManageAssignmentsViewModel
@{
    ViewData["Title"] = "Quản lý Lịch dạy & Học phần";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-3">
    <h2 class="mb-0">Quản lý Học Phần & Ngoại lệ</h2>
    <a asp-action="CreateSchedule" class="btn btn-success fw-bold shadow-sm">
        <i class="fas fa-plus-circle me-1"></i> Lên Lịch Học Mới
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show"><i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<div class="accordion" id="classAccordion">
    @foreach (var cls in Model.Classes)
    {
        var accId = "collapseClass_" + cls.Id;
        <div class="accordion-item mb-3 shadow-sm border-0 rounded">
            <h2 class="accordion-header">
                <button class="accordion-button collapsed fw-bold bg-white" type="button" data-bs-toggle="collapse" data-bs-target="#@accId">
                    <i class="fas fa-users text-primary me-2"></i> Lớp: @cls.Name
                </button>
            </h2>
            <div id="@accId" class="accordion-collapse collapse" data-bs-parent="#classAccordion">
                <div class="accordion-body bg-light p-3">
                    @if (!cls.AssignmentGroups.Any())
                    {
                        <p class="text-muted mb-0 fst-italic">Lớp này chưa được lên lịch môn học nào.</p>
                    }
                    else
                    {
                        <div class="row">
                            @foreach (var group in cls.AssignmentGroups)
                            {
                                <div class="col-md-6 mb-3">
                                    <div class="card h-100 border-left-success">
                                        <div class="card-body">
                                            <h5 class="card-title text-success fw-bold">@group.CourseName</h5>
                                            <p class="card-text mb-1"><i class="fas fa-chalkboard-teacher me-2 text-muted"></i>GV: @(group.Teacher?.FullName ?? "Chưa phân công")</p>
                                            <p class="card-text mb-3"><i class="fas fa-user-graduate me-2 text-muted"></i>Sĩ số: <span class="badge bg-secondary">@group.Students.Count()</span></p>
                                            
                                            <button type="button" class="btn btn-sm btn-outline-primary w-100"
                                                    onclick="openManageModal(@cls.Id, @group.CourseId, '@cls.Name', '@group.CourseName')">
                                                <i class="fas fa-user-edit me-1"></i> Chỉnh sửa Sinh viên (Học lại/Vượt)
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

<div class="modal fade" id="manageModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title"><i class="fas fa-tools me-2"></i> <span id="modalTitle"></span></h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body bg-light">
                <input type="hidden" id="modalClassId" />
                <input type="hidden" id="modalCourseId" />
                
                <div class="row mt-3">
                    <div class="col-md-5">
                        <label class="fw-bold text-danger"><i class="fas fa-users-slash me-1"></i> Toàn bộ sinh viên khác</label>
                        <select id="unassignedStudents" class="form-select mt-2" multiple style="height: 300px; font-size:14px;"></select>
                        <small class="text-muted">Chọn và bấm nút sang phải để cho phép Học Vượt / Học Lại.</small>
                    </div>
                    
                    <div class="col-md-2 d-flex flex-column justify-content-center align-items-center">
                        <button type="button" id="btnMoveRight" class="btn btn-success mb-2" title="Thêm vào lớp"><i class="fas fa-angle-double-right"></i> Thêm</button>
                        <button type="button" id="btnMoveLeft" class="btn btn-danger" title="Xóa khỏi lớp"><i class="fas fa-angle-double-left"></i> Bớt</button>
                    </div>
                    
                    <div class="col-md-5">
                        <label class="fw-bold text-success"><i class="fas fa-user-check me-1"></i> Sinh viên đang học môn này</label>
                        <select id="assignedStudents" class="form-select mt-2 border-success" multiple style="height: 300px; font-size:14px;"></select>
                        <small class="text-muted">Chọn và bấm nút sang trái để Hủy môn / Bảo lưu.</small>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy bỏ</button>
                <button type="button" class="btn btn-primary" onclick="saveAssignments()"><i class="fas fa-save me-1"></i> Lưu thay đổi</button>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .border-left-success {
            border-left: 4px solid #1cc88a !important;
        }
    </style>
}

@section Scripts {
    <script>
        var initialAssignedIds = []; // Biến lưu danh sách ID ban đầu để so sánh

        function openManageModal(classId, courseId, className, courseName) {
            $('#modalClassId').val(classId);
            $('#modalCourseId').val(courseId);
            $('#modalTitle').text('Quản lý Học Phần: ' + courseName + ' (Lớp ' + className + ')');
            
            // Xóa dữ liệu cũ
            $('#unassignedStudents, #assignedStudents').empty();
            initialAssignedIds = [];

            // Gọi AJAX lấy dữ liệu
            $.get('@Url.Action("GetStudentsForAssignment", "ClassAssignments")', { classId: classId, courseId: courseId }, function (data) {
                // Đổ data chưa gán
                data.unassigned.forEach(s => $('#unassignedStudents').append(new Option(s.name + ' (' + s.id + ')', s.id)));
                // Đổ data đã gán
                data.assigned.forEach(s => {
                    $('#assignedStudents').append(new Option(s.name + ' (' + s.id + ')', s.id));
                    initialAssignedIds.push(s.id.toString());
                });
                $('#manageModal').modal('show');
            });
        }

        // JS Di chuyển sinh viên qua lại
        $('#btnMoveRight').click(function () { $('#unassignedStudents option:selected').appendTo('#assignedStudents'); });
        $('#btnMoveLeft').click(function () { $('#assignedStudents option:selected').appendTo('#unassignedStudents'); });

        // JS Lưu dữ liệu
        function saveAssignments() {
            var classId = $('#modalClassId').val();
            var courseId = $('#modalCourseId').val();
            
            // Lấy danh sách ID hiện tại ở cột bên phải
            var currentAssignedIds = [];
            $('#assignedStudents option').each(function() { currentAssignedIds.push($(this).val()); });

            // So sánh để tìm ra người mới thêm và người bị xóa
            var idsToAdd = currentAssignedIds.filter(id => !initialAssignedIds.includes(id));
            var idsToRemove = initialAssignedIds.filter(id => !currentAssignedIds.includes(id));

            var payload = {
                ClassId: parseInt(classId),
                CourseId: parseInt(courseId),
                TeacherId: -1, // Backend tự động giữ nguyên GV cũ
                StudentIdsToAdd: idsToAdd.map(Number),
                StudentIdsToRemove: idsToRemove.map(Number)
            };

            // Gửi dữ liệu cập nhật về Server
            $.ajax({
                url: '@Url.Action("UpdateAssignments", "ClassAssignments")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(payload),
                headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
                success: function (res) {
                    if (res.success) { location.reload(); }
                    else { alert('Lỗi: ' + res.message); }
                }
            });
        }
    </script>
}