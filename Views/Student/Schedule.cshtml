@model IEnumerable<SIMS.Models.StudentScheduleViewModel>

@{
    ViewData["Title"] = "My Schedule";
}

<div class="container-fluid px-4">
    
    <div class="d-flex justify-content-between align-items-center mt-4 mb-3">
        <h1 class="mb-0">@ViewData["Title"]</h1>
        
        @if (Model != null && Model.Any())
        {
            <a asp-action="ExportScheduleCsv" class="btn btn-success shadow-sm">
                <i class="fas fa-file-excel me-2"></i> Xuất Lịch Học (Excel)
            </a>
        }
    </div>

    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
        <li class="breadcrumb-item active">Schedule</li>
    </ol>

    @if (ViewData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger"><i class="fas fa-exclamation-triangle me-2"></i>@ViewData["ErrorMessage"]</div>
    }
    else if (Model != null && Model.Any())
    {
        <div class="card bg-light text-dark mb-4 shadow-sm">
            <div class="card-body border-left-primary">
                <h5 class="card-title fw-bold">Xin chào, @ViewData["StudentName"]!</h5>
                <p class="card-text mb-0">Đây là lịch học chi tiết của bạn trong học kỳ này.</p>
                <p class="card-text"><small class="text-muted">Mã số sinh viên: @ViewData["StudentNumber"]</small></p>
            </div>
        </div>

        <div class="row">
            @foreach (var item in Model.OrderBy(i => i.CourseName))
            {
                <div class="col-xl-4 col-md-6 mb-4">
                    <div class="card border-left-primary shadow h-100 py-2">
                        <div class="card-body">
                            <div class="row no-gutters align-items-center">
                                <div class="col mr-2">
                                    <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                                        @item.CourseName
                                    </div>
                                    <div class="h5 mb-3 font-weight-bold text-gray-800">@item.ClassName</div>
                                    <div class="mb-2">
                                        <i class="fas fa-chalkboard-teacher fa-fw me-2 text-gray-400"></i>
                                        <strong>Giảng viên:</strong> @item.TeacherName
                                    </div>
                                    <div>
                                        <i class="fas fa-calendar-alt fa-fw me-2 text-gray-400"></i>
                                        <strong>Lịch học:</strong> @item.Schedule
                                    </div>
                                </div>
                                <div class="col-auto">
                                    <i class="fas fa-book-open fa-2x text-gray-300"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center mt-5 p-5 bg-white shadow-sm rounded">
            <i class="fas fa-calendar-times fa-4x text-muted mb-3"></i>
            <h4>Chưa có lịch học</h4>
            <p class="text-muted">Bạn chưa được xếp vào lớp học nào. Vui lòng quay lại sau nhé.</p>
        </div>
    }
</div>

@section Styles {
    <style>
        .border-left-primary {
            border-left: .25rem solid #4e73df !important;
        }

        .text-xs {
            font-size: .9rem;
        }

        .text-gray-300 {
            color: #dddfeb !important;
        }

        .text-gray-400 {
            color: #d1d3e2 !important;
        }

        .text-gray-800 {
            color: #5a5c69 !important;
        }
    </style>
}